<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="idea89" translate="label" sortOrder="500">
            <label>IDEA89</label>
        </tab>

        <section id="idea89" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>AI Shopping Assistant</label>
            <tab>idea89</tab>
            <resource>Idea89_Assistant::config</resource>

            <!-- ── General ─────────────────────────────────── -->
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>

                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Widget</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="api_key" translate="label comment" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Key</label>
                    <comment>Paste the API key from your IDEA89 merchant dashboard.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>

                <field id="assistant_name" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Assistant Name</label>
                    <comment>Name shown in the chat widget header, e.g. "Aria" or "Shop Helper".</comment>
                </field>

                <field id="store_context" translate="label comment" type="textarea" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Store Context</label>
                    <comment>Describe what your store sells so the assistant can answer general questions. E.g. "We specialise in outdoor gardening tools and accessories for home and professional gardeners."</comment>
                </field>

                <field id="test_connection" translate="label" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Test Connection</label>
                    <frontend_model>Idea89\Assistant\Block\Adminhtml\TestConnectionButton</frontend_model>
                    <comment>Verifies the API key and connection to IDEA89.</comment>
                </field>

                <field id="sync_now" translate="label" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sync Now</label>
                    <frontend_model>Idea89\Assistant\Block\Adminhtml\SyncNowButton</frontend_model>
                    <comment>Pushes products, categories, and CMS pages to IDEA89. Runs automatically every night.</comment>
                </field>
            </group>

            <!-- ── Widget Appearance ───────────────────────── -->
            <group id="widget" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Widget Appearance</label>

                <field id="position" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Position</label>
                    <source_model>Idea89\Assistant\Model\Config\Source\WidgetPosition</source_model>
                </field>

                <field id="brand_color" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Brand Colour</label>
                    <comment>Hex colour code, e.g. #2563eb</comment>
                    <validate>validate-color</validate>
                </field>
            </group>

            <!-- ── Content Sync ────────────────────────────── -->
            <group id="sync" translate="label" type="text" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Content Sync</label>
                <comment>Choose which content types are sent to IDEA89 to enrich the assistant's knowledge.</comment>

                <field id="sync_products" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sync Products</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Sync your product catalog (recommended: Yes).</comment>
                </field>

                <field id="sync_categories" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sync Categories</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Lets the assistant know what product categories your store has.</comment>
                </field>

                <field id="sync_cms" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sync CMS Pages</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Sync About Us, FAQs, contact pages etc. so the assistant can answer policy questions.</comment>
                </field>

                <field id="sync_store_info" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sync Store Info</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Sends store name and context description to IDEA89.</comment>
                </field>
            </group>

            <!-- ── Store Locator ───────────────────────────── -->
            <group id="locator" translate="label comment" type="text" sortOrder="27" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Store Locator</label>
                <comment><![CDATA[
<div style="padding:10px 14px;margin:0 0 6px;background:#fff8e1;border:1px solid #f4d35e;border-radius:6px;color:#5a4500;font-size:13px;line-height:1.5;">
  <strong style="color:#7a5a00;">✨ Pro plan feature.</strong> The Store Locator is included on the <strong>Pro</strong> tier and above.
  If you're on Starter, upgrade in your <a href="https://app.idea89.com/billing" target="_blank" rel="noopener" style="color:#5a4500;text-decoration:underline;">IDEA89 dashboard</a> to use these settings.
</div>
<div style="font-size:12.5px;color:#555;line-height:1.5;">
  Online-only retailer? Set <strong>Enable Store Locator</strong> below to <em>No</em> — the page and chat-widget locator both disappear from your storefront.<br/>
  All content fields fall back to sensible defaults when blank. Leave layout blank to inherit the global setting from your dashboard.<br/>
  Tip: you can embed the locator inside any CMS page via the <strong>IDEA89 Store Locator</strong> widget.
</div>
                ]]></comment>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Store Locator</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[
<strong>Yes</strong> — the store finder page is live and the CMS widget renders.<br/>
<strong>No</strong> — the page returns 404 and the CMS widget renders nothing. Pick this if you sell online only.<br/>
<em>Note: the chat assistant only suggests showrooms if you've seeded locations in the dashboard, so online-only stores naturally never see them either way.</em>
                    ]]></comment>
                </field>

                <field id="url_path" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>URL Path</label>
                    <comment><![CDATA[The URL slug for the store finder page, e.g. <code>store-finder</code>, <code>showrooms</code>, <code>stores</code>, <code>find-a-shop</code>, <code>store_locator</code>. Lowercase letters, numbers, hyphens (<code>-</code>) and underscores (<code>_</code>) only — anything else is stripped on save. Leave blank to use <code>store-finder</code>. The save will fail with a clear error if the path already belongs to a Magento module, CMS page, product, or category. <strong>Cache flush required after change.</strong>]]></comment>
                    <!-- NO `<validate>` here on purpose. Magento's bundled
                         frontend validators are each missing at least one of
                         hyphen, underscore, or both: validate-code rejects
                         hyphens (false negative — blocks legitimate slugs like
                         `find-a-shop`), validate-identifier passes slashes and
                         `.html` (false positive — slug then mismatches the
                         backend-normalised value). The backend validator
                         Idea89\Assistant\Model\Config\Backend\LocatorUrlPath
                         is the single source of truth: it strips disallowed
                         characters, rejects reserved slugs, and surfaces
                         collisions with a named-entity error banner.
                         Better to fail on submit with an accurate message
                         than block on the client with a wrong one. -->
                    <backend_model>Idea89\Assistant\Model\Config\Backend\LocatorUrlPath</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="layout" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Page Layout</label>
                    <source_model>Idea89\Assistant\Model\Config\Source\StorefinderLayout</source_model>
                    <comment>Fullwidth = edge-to-edge map (recommended); Boxed = max-width rounded card. Overrides the dashboard setting when not blank.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="page_title" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>SEO Page Title</label>
                    <comment>Browser tab + search-result title. Default: "Find a store".</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="meta_description" translate="label comment" type="textarea" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>SEO Meta Description</label>
                    <comment>Shown in search results under the page title. Aim for 140–160 characters.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="hero_eyebrow" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Hero Eyebrow</label>
                    <comment>Small label above the page title, e.g. "Showrooms", "Where to buy", "Visit a branch". Default: "Showrooms".</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="hero_h1" translate="label comment" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Hero Title (H1)</label>
                    <comment>Main page heading. Default: "Find a store near you".</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="hero_subhead" translate="label comment" type="textarea" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Hero Subhead</label>
                    <comment>One-line introduction below the title.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="help_heading" translate="label comment" type="text" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Help Section Heading</label>
                    <comment>The heading of the help block below the map.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="help_body" translate="label comment" type="textarea" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Help Section Body</label>
                    <comment>A short paragraph offering help. Often used to mention phone support or live chat.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="help_cta_label" translate="label comment" type="text" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Help CTA Label</label>
                    <comment>Button text below the help message, e.g. "Get in touch", "Contact us".</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="help_cta_url" translate="label comment" type="text" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Help CTA URL</label>
                    <comment>Where the help button links to. Can be a relative URL (/contact), an external URL, or a mailto: link.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- ── Advanced ────────────────────────────────── -->
            <group id="advanced" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Advanced</label>

                <field id="api_url" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API URL (Server-side)</label>
                    <comment>Used for product sync from Magento to IDEA89. For local dev with Docker: http://host.docker.internal:3000</comment>
                </field>

                <field id="widget_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Widget URL (Browser-side)</label>
                    <comment>Used for the chat widget script tag loaded in the shopper's browser. For local dev: http://localhost:3000. Leave blank to use the API URL.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
