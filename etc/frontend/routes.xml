<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="idea89_locator" frontName="store-finder">
            <module name="Idea89_Assistant"/>
        </route>
        <!-- JSON API endpoints used by the chat widget's same-origin order
             tracking flow (Pattern A — order data stays on the merchant's
             storefront, never proxies through IDEA89). All endpoints under
             this frontName authenticate via the Magento customer session
             (logged-in flow) or email + increment ID (guest flow). -->
        <route id="idea89" frontName="idea89">
            <module name="Idea89_Assistant"/>
        </route>
    </router>
</config>
