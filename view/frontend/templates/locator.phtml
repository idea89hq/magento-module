<?php /* NO `async` on these <script type="module"> tags: modules default to
        deferred (run after DOM parse) AND in source order. Adding async would
        let locator-google.js race ahead of locator.js, find globalThis.
        __idea89LocatorRegisterGoogle still undefined, and silently fail to
        register the Google adapter — leaving the locator on Stadia. */ ?>
<script type="module" src="<?= /* @noEscape */ $apiBase ?>/widget/v1/locator.js"></script>
<?php if ($mapProvider === 'google'): ?>
<script type="module" src="<?= /* @noEscape */ $apiBase ?>/widget/v1/locator-google.js"></script>
<?php endif; ?>

<script>
// Forward locator:analytics events to the existing analytics POST.
document.querySelector('.idea89-locator-host')?.addEventListener('locator:analytics', function (e) {
  var detail = e.detail || {};
  fetch('<?= /* @noEscape */ $apiBaseJs ?>/widget/v1/analytics', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-IDEA89-Key': '<?= /* @noEscape */ $apiKeyJs ?>' },
    body: JSON.stringify({ name: detail.name, properties: detail.properties, entry_point: 'store-finder' }),
    keepalive: true,
  }).catch(function () {});
});
</script>
