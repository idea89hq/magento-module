<?php
/** @var \Idea89\Assistant\Block\Locator $block */
$locations = $block->getLocations();
$apiBase = $block->escapeHtmlAttr($block->getApiBase());
$apiKey = $block->escapeHtmlAttr($block->getApiKey());
$apiBaseJs = $block->escapeJs($block->getApiBase());
$apiKeyJs  = $block->escapeJs($block->getApiKey());
$mapProvider = $block->escapeHtmlAttr($block->getMapProvider());
$mapKey = $block->getMapKey();
$mapKeyAttr = $mapKey !== null ? $block->escapeHtmlAttr($mapKey) : null;
$defaultCountry = $block->getDefaultCountryCode();
$defaultCountryAttr = $defaultCountry !== null ? $block->escapeHtmlAttr($defaultCountry) : null;
$nearestCount = (int) $block->getNearestResultsCount();
// Brand color from the dashboard cfg — used to theme the storefront
// hero + help section so the page matches the merchant's accent.
// Falls back to IDEA89 emerald.
$brandColor = $block->getBrandColor();
$brandColorAttr = $brandColor !== null
    ? $block->escapeHtmlAttr($brandColor)
    : '#0B6B47';
// Phase 10: 'fullwidth' (edge-to-edge map with floating panel) vs
// 'boxed' (max-width rounded card). Merchant picks in dashboard
// /settings/locator; default is fullwidth.
$layoutMode = $block->getStorefinderLayout();

// Merchant-configured copy (Magento admin → IDEA89 → Store Locator).
// All fields fall back to typed defaults inside LocatorConfig when blank.
$cfg            = $block->getLocatorConfig();
$heroEyebrow    = (string) $cfg->getHeroEyebrow();
$heroH1         = (string) $cfg->getHeroH1();
$heroSubhead    = (string) $cfg->getHeroSubhead();
$helpHeading    = (string) $cfg->getHelpHeading();
$helpBody       = (string) $cfg->getHelpBody();
$helpCtaLabel   = (string) $cfg->getHelpCtaLabel();
$helpCtaUrlRaw  = (string) $cfg->getHelpCtaUrl();
// Allow merchant URL to be relative ("/contact"), absolute, or mailto:.
$helpCtaUrlAttr = $block->escapeUrl($helpCtaUrlRaw) ?: $helpCtaUrlRaw;

// Trust-signal stats computed from the actual locations dataset so the
// hero numbers always match what the locator shows. Falls back to
// sensible defaults for empty / draft tenants.
$storeCount = is_array($locations) ? count($locations) : 0;
$countryCount = 0;
$cityCount = 0;
$countries = [];
$cities = [];
foreach ($locations as $loc) {
    // /widget/v1/locations returns the nested NearestLocation shape:
    // { address: { line_1, city, country_code, ... }, ... }
    $addr = is_array($loc['address'] ?? null) ? $loc['address'] : [];
    $cc = $addr['country_code'] ?? null;
    if ($cc && !isset($countries[$cc])) { $countries[$cc] = true; }
    $city = $addr['city'] ?? null;
    if ($city && !isset($cities[$city])) { $cities[$city] = true; }
}
$countryCount = count($countries);
$cityCount = count($cities);

// Display strings — coverage handles the single-country case cleanly
// ("UK" rather than the awkward "1 country") and adds the "+" suffix
// when there are more than one.
$coverageLabel = $countryCount > 1
    ? (string) $countryCount . ' countries'
    : (in_array('GB', array_keys($countries), true) ? 'United Kingdom' : 'In your region');
$citiesLabel = $cityCount > 0 ? ((string) $cityCount . ' cities') : '—';
?>

<?php foreach ($locations as $loc): ?>
<script type="application/ld+json"><?= /* @noEscape */ $block->renderStoreJsonLd($loc) ?></script>
<?php endforeach; ?>

